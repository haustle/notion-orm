{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"rootDir": "..",
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": false,
		"skipLibCheck": true,
		"types": ["bun-types", "node"]
	},
	"include": ["./**/*.ts", "./**/*.d.ts", "../src/babel-types.d.ts"],
	"exclude": ["./golden/**"]
}
