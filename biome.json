{
  "$schema": "https://biomejs.dev/schemas/2.3.4/schema.json",
  "plugins": [
    "./plugins/no-type-assertion.grit"
  ],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "tab",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80,
    "attributePosition": "auto"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noInnerDeclarations": "error",
        "noNestedComponentDefinitions": "warn",
        "useHookAtTopLevel": "error"
      },
      "suspicious": {
        "noConsole": "warn"
      },
      "style": {
        "useBlockStatements": "error",
        "noDefaultExport": "error"
      },
      "complexity": {
        "noUselessTypeConstraint": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "bracketSameLine": true
    }
  },
  "overrides": [
    {
					"includes": ["tests/golden/**/*.ts", "tests/golden/**/*.d.ts"],
					"linter": {
						"rules": {
							"correctness": {
								"noUnusedImports": "off"
							},
							"style": {
								"noDefaultExport": "off"
							}
						}
					}
				},
				{
					"includes": ["website/src/**/*.ts", "website/src/**/*.tsx"],
					"linter": {
						"rules": {
							"style": {
								"noDefaultExport": "off"
							}
						}
					}
				}
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
